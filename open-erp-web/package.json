{
  "name": "open-erp-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "format": "prettier --write \"src/**/*.{ts,js,json,css,scss,html,md}\" \"public/**/*.{json,md,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,css,scss,html,md}\" \"public/**/*.{json,md,html}\""
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "21.2.1",
    "@angular/compiler": "21.2.1",
    "@angular/core": "21.2.1",
    "@angular/forms": "21.2.1",
    "@angular/platform-browser": "21.2.1",
    "@angular/router": "21.2.1",
    "@jsverse/transloco": "8.2.1",
    "@primeuix/themes": "2.0.3",
    "@types/leaflet-draw": "1.0.13",
    "ajv": "8.18.0",
    "leaflet": "1.9.4",
    "leaflet-draw": "1.0.4",
    "ngx-vflow": "2.5.0",
    "primeicons": "7.0.0",
    "primeng": "21.1.3",
    "rxjs": "7.8.2",
    "socket.io-client": "4.8.3",
    "tailwindcss-primeui": "0.6.1",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.1",
    "@angular/cli": "21.2.1",
    "@angular/compiler-cli": "21.2.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/geojson": "7946.0.16",
    "@types/leaflet": "1.9.21",
    "@types/node": "^25.6.2",
    "jsdom": "28.1.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.1",
    "typescript": "~5.9.2",
    "vitest": "4.0.18"
  }
}
