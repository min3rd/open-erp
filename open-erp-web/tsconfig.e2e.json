{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "outDir": "./e2e-dist",
    "baseUrl": ".",
    "types": ["node", "@playwright/test"]
  },
  "include": ["e2e/**/*.ts"],
  "exclude": ["node_modules"]
}
