{
  "name": "open-erp",
  "private": true,
  "workspaces": [
    "open-erp-services",
    "open-erp-shared",
    "open-erp-web",
    "open-erp-mobile"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspace=open-erp-services && npm install --workspace=open-erp-shared && npm install --workspace=open-erp-web",
    "audit:fix:all": "npm audit fix && npm audit fix --workspace=open-erp-services && npm audit fix --workspace=open-erp-shared && npm audit fix --workspace=open-erp-web",
    "services:dev": "npm run start:dev --workspace=open-erp-services",
    "web:dev": "node -e \"setTimeout(() => {}, 6000)\" && npm run start --workspace=open-erp-web",
    "shared:build": "npm run build --workspace=open-erp-shared",
    "shared:watch": "npm run watch --workspace=open-erp-shared",
    "dev": "npm run shared:build && concurrently \"npm run services:dev\" \"npm run shared:watch\" \"npm run web:dev\""
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "^7.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "concurrently": "^8.0.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.20.0"
  }
}
